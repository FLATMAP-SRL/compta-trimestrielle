# =============================================================================
#  compta-trimestrielle — configuration d'instance
#  Copiez ce fichier en `.env` (gitignoré) et remplissez VOS valeurs.
#  Ce fichier ne contient que des IDENTIFIANTS d'instance, PAS de secret vivant.
#  L'authentification Accountable (token) est gérée à part par le CLI `accountable`
#  (voir docs/accountable-cli.md), pas ici.
# =============================================================================

# --- Société ---
COMPANY_NAME=""              # ex. "ACME SRL"
COMPANY_LEGAL_FORM=""        # ex. "SRL", "SPRL", "SA"
COMPANY_VAT=""               # n° TVA, ex. "BE0123456789" — sert à vérifier que chaque facture est bien au nom de la société

# --- Accountable ---
ACCOUNTABLE_EMAIL=""         # email de connexion Accountable (login Google), ex. "vous@exemple.be"

# --- Comptes bancaires (IBAN tels qu'ils apparaissent dans Accountable) ---
BANK_MAIN_IBAN=""            # compte pro principal — la plupart des transactions y passent
BANK_MASTERCARD_ACCOUNT_REF="" # (optionnel) pseudo-compte Accountable alimenté par imports manuels de relevés carte ; laisser vide si non utilisé

# --- Carte de crédit / Mastercard Business (optionnel) ---
MASTERCARD_LAST4=""          # 4 derniers chiffres de la carte, ex. "1234"
MASTERCARD_CLIENT_REF=""     # référence client banque pour les relevés (ex. Home'Bank ING)

# --- Google Cloud Billing (optionnel) ---
# Un bloc ID/LABEL par compte de facturation. Dupliquez _2, _3… si besoin.
GCLOUD_BILLING_1_ID=""       # format "XXXXXX-XXXXXX-XXXXXX" (visible dans la console Cloud Billing)
GCLOUD_BILLING_1_LABEL=""    # ex. "My Billing Account" (payé par carte débit)
GCLOUD_BILLING_2_ID=""
GCLOUD_BILLING_2_LABEL=""    # ex. "Firebase Payment"

# --- Fournisseurs à identifiant de compte (optionnel) ---
SUPPLIER_4411_CLIENT_ID=""   # n° client du profil PRO sur my.4411.be (le profil perso/EASY est distinct)

# --- Chemins locaux ---
DOWNLOADS_DIR="~/Downloads"                                   # où atterrissent les téléchargements du navigateur
CHROME_PROFILE_DIR="~/.cache/chrome-devtools-mcp/chrome-profile" # profil du MCP chrome-devtools

# --- Convention de dossiers (voir docs/workflow.md) ---
# Dossier d'un trimestre : minuscule-tiret, ex. "t3-2026"
# Suffixe des fichiers   : MAJUSCULE-underscore, ex. "T3_2026"
QUARTER_DIR_ROOT="~/Dev"     # où sont créés les dossiers tX-YYYY
